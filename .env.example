# Copy this to .env.local and fill in your values
# This file is safe to commit — it contains no secrets

# Your n8n webhook URL (from your n8n workflow Webhook node)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/nestcare-report

# Optional: a secret token to verify requests come from your form
WEBHOOK_SECRET=your-random-secret-here
